        <mxCell id="r4" edge="1" parent="1" source="users" style="endArrow=none;html=1;rounded=0;strokeWidth=2;" target="programs" value="athlete: 1 to N&lt;br&gt;receives/&lt;br&gt;coach : 1 to N creates">
